# Gradle / Kotlin 构建缓存
/.gradle/
/.kotlin/
/build/

# Android 构建产物
/.cxx/
/.externalNativeBuild/
/app/release/
/captures/

# 本地配置和临时分析产物
/local.properties
/.analysis/
/.tmp/

